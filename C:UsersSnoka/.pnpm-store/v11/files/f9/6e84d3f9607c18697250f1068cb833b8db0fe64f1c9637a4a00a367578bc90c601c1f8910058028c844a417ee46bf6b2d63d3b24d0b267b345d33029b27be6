@custom-variant airmail (.bloop_container &);

@custom-variant apple-mail-10 (.Singleton &);
@custom-variant apple-mail ([class^="apple-mail"] &);

@custom-variant comcast (.mail-detail-content &);

@custom-variant edison (#edo-container &);
@custom-variant edison-ios (.edo &);
@custom-variant edison-android (.edo-email-view &);

@custom-variant freenet (body[marginwidth][marginheight] &);

@custom-variant gmail (u + .body &);
@custom-variant gmail-android (div > u + .body &);
@custom-variant gmail-ipad {
  @media only screen and (min-device-width: 768px) and (max-device-width: 1366px) {
    u + .body & {
      @slot;
    }
  }
}

@custom-variant ios-10 (@supports (-webkit-overflow-scrolling:touch) and (color:#ffff));
@custom-variant ios-13 ([class^="apple-mail"] &);
@custom-variant ios (@supports (-webkit-overflow-scrolling:touch) and (aspect-ratio: 1 / 1));

@custom-variant notion (#mail-content-wrapper &);

@custom-variant ox (&[class^="ox-"] &);

@custom-variant ogsc ([data-ogsc] &);
@custom-variant ogsb ([data-ogsb] &);

@custom-variant outlook-mac (#converted-body &);
@custom-variant outlook-android (#converted-body &);

@custom-variant spark (.c17637 &);

@custom-variant superhuman (.ShadowHTML &);

@custom-variant thunderbird (.moz-text-html &);

@custom-variant yahoo (.\& &);
