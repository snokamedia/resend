@theme {
    --breakpoint-xs: 430px;
    --breakpoint-sm: 600px;
    --breakpoint-md: 768px;
    --breakpoint-lg: 1024px;
    --breakpoint-xl: 1280px;
    --breakpoint-2xl: 1536px;
  }

@custom-variant xs (@media (max-width: 430px));
@custom-variant sm (@media (max-width: 600px));
@custom-variant md (@media (max-width: 768px));
@custom-variant lg (@media (max-width: 1024px));
@custom-variant xl (@media (max-width: 1280px));
@custom-variant 2xl (@media (max-width: 1536px));
